QWidget {
    background-color: #D9D9D9;
}
QPushButton#photoButton {
    background-color: transparent;
    color: #000000;
    border: 3px solid black;
    border-radius: 60px;
    font-size: 50px;
    padding: 0px;
    text-align: center;
    vertical-align: middle;
}
QPushButton#photoButton:hover {
    background-color: #979797;
}
QPushButton#photoButton:icon {
    /* Это гарантирует, что иконка будет центрирована внутри круга */
    qproperty-iconSize: 120px 120px;
}
QLineEdit, QDateEdit {
    background-color: #e0e0e0;
    color: #000000;
    border: 2px solid black;
    border-radius: 15px;
    padding: 5px 15px;
    min-height: 30px;
    font-size: 18px;
}
QLabel {
    color: #000000;
    font-size: 24px;
    margin-top: 5px;
}
QPushButton#saveButton {
    background-color: #000000;
    color: white;
    border-radius: 25px; /* Большая величина для эффекта овала */
    min-width: 150px;
    min-height: 40px;
    font-size: 16px;
    padding: 10px;
}
QPushButton#saveButton:hover {
    background-color: #3d3d3d;
}
QPushButton#removePhotoButton {
    background-color: transparent;
    color: #cc0000;
    border: 2px solid #cc0000;
    border-radius: 15px;
    font-size: 14px;
    min-width: 120px;
    min-height: 30px;
    padding: 5px 10px;
}
QPushButton#removePhotoButton:hover {
    background-color: #cc0000;
    color: white;
}
